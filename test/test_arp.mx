// test_arp.mx — MORT OS answers an ARP "who has 10.0.2.15?".
//! expect: 42
//! expect: 2054
//! expect: 2
//! expect: 82
//! expect: 15
//! expect: 2
//! expect: 82
//! expect: 0

fn main() -> int {
    let our_mac: [u8; 6] = [0x52, 0x54, 0x00, 0x12, 0x34, 0x56];
    net_set_mac(&our_mac as u64);
    // g_our_ip defaults to 10.0.2.15.

    let requester_mac: [u8; 6] = [0x52, 0x54, 0x00, 0xAA, 0xBB, 0xCC];
    let requester_ip: [u8; 4] = [10, 0, 2, 2];
    let our_ip: [u8; 4] = [10, 0, 2, 15];

    // Build a broadcast ARP request: "who has 10.0.2.15?"
    let rx: [u8; 64] = [0; 64];
    let rxb: u64 = &rx as u64;
    let bcast: [u8; 6] = [0; 6];
    mac_broadcast(&bcast as u64);
    eth_build_header(rxb, &bcast as u64, &requester_mac as u64, ETH_ARP);
    let a: u64 = eth_payload(rxb);
    be16_store(a, 1);                       // htype: Ethernet
    be16_store(a + 2, 0x0800);              // ptype: IPv4
    let hl: *u8 = (a + 4) as *u8; *hl = 6;
    let pl: *u8 = (a + 5) as *u8; *pl = 4;
    be16_store(a + 6, ARP_REQUEST);
    mac_copy(a + 8, &requester_mac as u64); // sender MAC
    ip4_copy(a + 14, &requester_ip as u64); // sender IP
    ip4_copy(a + 24, &our_ip as u64);       // target IP = us

    // Answer it.
    let tx: [u8; 64] = [0; 64];
    let txb: u64 = &tx as u64;
    let n: u32 = net_handle_frame(rxb, 42, txb);
    print(n as i64);                        // 42 = 14 + 28
    print(eth_type(txb) as i64);            // 2054 = 0x0806 (ARP)

    let ra: u64 = eth_payload(txb);
    print(arp_oper(ra) as i64);             // 2 (reply)
    let sha0: *u8 = arp_sha(ra) as *u8;
    print(*sha0 as i64);                    // 82 = 0x52, our MAC's first byte
    let spa3: *u8 = (arp_spa(ra) + 3) as *u8;
    print(*spa3 as i64);                    // 15, our IP's last octet
    let tpa3: *u8 = (arp_tpa(ra) + 3) as *u8;
    print(*tpa3 as i64);                    // 2, the requester's IP
    let ethdst0: *u8 = txb as *u8;
    print(*ethdst0 as i64);                 // 82, reply is unicast to the asker

    // An ARP for a different IP is not ours to answer.
    let other_ip: [u8; 4] = [10, 0, 2, 99];
    ip4_copy(a + 24, &other_ip as u64);
    let m: u32 = net_handle_frame(rxb, 42, txb);
    print(m as i64);                        // 0
    return 0;
}
